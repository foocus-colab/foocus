   "source": [
    "# ===== 1️⃣ Criar ambiente virtual isolado =====\n",
    "!python -m venv /content/fooocus_env\n",
    "!/content/fooocus_env/bin/pip install --upgrade pip\n",
    "\n",
    "# ===== 2️⃣ Instalar versões compatíveis =====\n",
    "!/content/fooocus_env/bin/pip install numpy==1.26.4\n",
    "!/content/fooocus_env/bin/pip install cupy-cuda12x==13.6.0\n",
    "!/content/fooocus_env/bin/pip install pygit2==1.15.1\n",
    "\n",
    "# ===== 3️⃣ Clonar Fooocus =====\n",
    "%cd /content\n",
    "!git clone https://github.com/lllyasviel/Fooocus.git\n",
    "%cd /content/Fooocus\n",
    "\n",
    "# ===== 4️⃣ Rodar usando o Python do venv =====\n",
    "!/content/fooocus_env/bin/python entry_with_update.py --share --always-high-vram\n"
